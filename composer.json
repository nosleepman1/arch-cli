{
    "name": "nosleepman/arch-cli",
    "description": "A Laravel package to generate complete backend architecture from business models",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nosleepman\\ArchCLI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nosleepman\\ArchCLI\\ArchCLIServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}